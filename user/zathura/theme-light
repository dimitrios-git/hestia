# zathura colours — light (theme-dark / theme-light pair; the bootstrap
# symlinks the `theme_variant` one to ~/.config/zathura/theme, `include`d by
# zathurarc). zathura takes "#RRGGBB" (+ rgba(...) for translucent highlights).

# --- window / page area ---
set default-bg          "#f5f5f5"
set default-fg          "#1a1a1a"
set render-loading-bg   "#f5f5f5"
set render-loading-fg   "#1a1a1a"

# --- statusbar (bottom bar) ---
set statusbar-bg        "#e4e4e4"
set statusbar-fg        "#1a1a1a"

# --- inputbar (the ':' command line) ---
set inputbar-bg         "#e4e4e4"
set inputbar-fg         "#1a1a1a"

# --- notifications (info / warning / error) ---
set notification-bg         "#e4e4e4"
set notification-fg         "#1a1a1a"
set notification-warning-bg "#af5f00"
set notification-warning-fg "#ffffff"
set notification-error-bg   "#9b0000"
set notification-error-fg   "#ffffff"

# --- search highlights (translucent so the text shows through) ---
# all matches = blue; the active/focused match = accent
set highlight-color        "rgba(0, 95, 175, 0.35)"
set highlight-active-color "rgba(124, 58, 237, 0.5)"

# --- completion menu (Tab) ---
set completion-bg           "#e4e4e4"
set completion-fg           "#1a1a1a"
set completion-group-bg     "#f5f5f5"
set completion-group-fg     "#7c3aed"
set completion-highlight-bg "#7c3aed"
set completion-highlight-fg "#ffffff"

# --- index / table of contents ---
set index-bg        "#f5f5f5"
set index-fg        "#1a1a1a"
set index-active-bg "#7c3aed"
set index-active-fg "#ffffff"

# --- document recolouring (invert page content toward the theme) ---
set recolor            false
set recolor-keephue    true
set recolor-lightcolor "#f5f5f5"
set recolor-darkcolor  "#1a1a1a"
