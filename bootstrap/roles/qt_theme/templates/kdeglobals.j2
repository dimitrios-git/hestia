# hestia Qt/KDE colour scheme ({{ qt_scheme.name }}) — RENDERED by the
# qt_theme role from templates/kdeglobals.j2 (palette: themes/hestia/palette.yml;
# the scheme dict comes from qt_theme_schemes[<variant>], M7). Do NOT edit the rendered
# copy; it is overwritten on the next bootstrap. The same body is written per variant to
# ~/.local/share/color-schemes/<name>.colors (KColorSchemeManager lists both — e.g.
# Kdenlive's theme menu) and, for the ACTIVE `theme_variant`, to ~/.config/kdeglobals
# (KDE apps read colours here via KColorScheme). See docs/theming.md (Qt/KDE track).
{% macro rgb(h) -%}
{{ h[1:3] | int(base=16) }},{{ h[3:5] | int(base=16) }},{{ h[5:7] | int(base=16) }}
{%- endmacro %}
{% set groups = [
  {'name': 'Colors:Window',        'bg': qt_scheme.surface,     'alt': qt_scheme.surface_alt},
  {'name': 'Colors:View',          'bg': qt_scheme.bg,          'alt': qt_scheme.surface},
  {'name': 'Colors:Button',        'bg': qt_scheme.surface_alt, 'alt': qt_scheme.border},
  {'name': 'Colors:Header',        'bg': qt_scheme.surface,     'alt': qt_scheme.surface_alt},
  {'name': 'Colors:Tooltip',       'bg': qt_scheme.surface_alt, 'alt': qt_scheme.border},
  {'name': 'Colors:Complementary', 'bg': qt_scheme.bg,          'alt': qt_scheme.surface_alt},
] -%}
{% for g in groups %}
[{{ g.name }}]
BackgroundNormal={{ rgb(g.bg) }}
BackgroundAlternate={{ rgb(g.alt) }}
DecorationFocus={{ rgb(qt_scheme.accent) }}
DecorationHover={{ rgb(qt_scheme.link) }}
ForegroundActive={{ rgb(qt_scheme.accent) }}
ForegroundInactive={{ rgb(qt_scheme.dim) }}
ForegroundLink={{ rgb(qt_scheme.link) }}
ForegroundNegative={{ rgb(qt_scheme.negative) }}
ForegroundNeutral={{ rgb(qt_scheme.neutral) }}
ForegroundNormal={{ rgb(qt_scheme.text) }}
ForegroundPositive={{ rgb(qt_scheme.positive) }}
ForegroundVisited={{ rgb(qt_scheme.visited) }}

{% endfor %}
[Colors:Selection]
BackgroundNormal={{ rgb(qt_scheme.accent) }}
BackgroundAlternate={{ rgb(qt_scheme.accent_dark) }}
DecorationFocus={{ rgb(qt_scheme.accent) }}
DecorationHover={{ rgb(qt_scheme.accent) }}
ForegroundActive={{ rgb(qt_scheme.accent_fg) }}
ForegroundInactive={{ rgb(qt_scheme.text) }}
ForegroundLink={{ rgb(qt_scheme.accent_fg) }}
ForegroundNegative={{ rgb(qt_scheme.negative) }}
ForegroundNeutral={{ rgb(qt_scheme.neutral) }}
ForegroundNormal={{ rgb(qt_scheme.accent_fg) }}
ForegroundPositive={{ rgb(qt_scheme.positive) }}
ForegroundVisited={{ rgb(qt_scheme.accent_fg) }}

[General]
ColorScheme={{ qt_scheme.name }}
Name={{ qt_scheme.name }}
accentColorFromWallpaper=false
AccentColor={{ rgb(qt_scheme.accent) }}
shadeSortColumn=true

[KDE]
contrast=4

[WM]
activeBackground={{ rgb(qt_scheme.surface) }}
activeBlend={{ rgb(qt_scheme.accent) }}
activeForeground={{ rgb(qt_scheme.text) }}
inactiveBackground={{ rgb(qt_scheme.bg) }}
inactiveBlend={{ rgb(qt_scheme.dim) }}
inactiveForeground={{ rgb(qt_scheme.dim) }}
