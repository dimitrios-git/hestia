---
# Per-host Ansible variables for `localhost` (this machine).
#
# Copy this file to `localhost.yml` (same dir) and fill in this host's REAL
# values. `localhost.yml` is gitignored so the personal values never reach the
# public repo; this `.example` is the committed, redacted template.
#
#   cp localhost.yml.example localhost.yml   # then edit
#
# Ansible auto-loads host_vars/<inventory_hostname>.yml, so the override applies
# with no extra flags.

# Home LAN subnet allowed to reach the Samba share (smb.conf `hosts allow`).
# Find it with: ip -o -4 addr show | awk '{print $4}'
samba_lan_subnet: "192.0.2.0/24"    # e.g. 192.168.1.0/24

# Where your music library lives (cmus browser default + the `U` rescan binding).
# Defaults to ~/Music if unset — override only if your library is elsewhere.
cmus_music_dir: "/mnt/storage/Music"   # e.g. an external mount
