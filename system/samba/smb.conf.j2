#
# Samba config for {{ system_hostname | default('estia') }} — file exchange with the Windows laptop over Tailscale.
# Tracked in the dotfiles repo as system/samba/smb.conf.j2; this is a LAYER-(a)
# system config — RENDERED BY ANSIBLE (the `samba` role) and copied to
# /etc/samba/smb.conf (never symlinked). The host-specific LAN subnet comes from
# host_vars (samba_lan_subnet) — see bootstrap/host_vars/localhost.yml.example.
# Full deploy runbook: system/samba/README.md. Design: docs/file-sharing-design.md.
#
# SECURITY MODEL: smbd listens on all interfaces (Samba 4.22 can't bind the
# Tailscale tun), and access is confined at the SMB LAYER by hosts allow/deny —
# only loopback, the home LAN, and the Tailscale CGNAT range may authenticate;
# everything else is rejected before auth. The LAN is allowed deliberately (full
# gigabit at home vs the tunnel's ~575 Mbit). Per-node restriction can live in the
# Tailscale ACL; this file is the coarse, on-host enforcement.
#

[global]
   # --- Access control: LAN + Tailscale ---
   # smbd listens on all interfaces (Samba 4.22 can't bind the Tailscale tun).
   # Access is confined at the SMB layer by hosts allow/deny: only loopback, the
   # local LAN, and the Tailscale CGNAT range may authenticate — everything else
   # is rejected before auth. The LAN is allowed deliberately: on the trusted home
   # LAN, mapping the share by LAN IP gives full gigabit, whereas Tailscale always
   # WireGuard-encrypts (even on a same-LAN path) and caps ~575 Mbit. Use the LAN
   # IP when home, the Tailscale IP when remote (two Windows drive mappings).
   hosts allow = 127.0.0.1 {{ samba_lan_subnet }} {{ samba_tailscale_cgnat }}
   hosts deny = 0.0.0.0/0

   # --- Protocol ---
   server min protocol = SMB3
   client min protocol = SMB2
   # No SMB-level encryption directive: the transport already runs inside the
   # Tailscale/WireGuard tunnel, so SMB3 encryption would only add CPU cost.

   # --- No guests / anonymous ---
   server role = standalone server
   map to guest = never
   restrict anonymous = 2

   # --- Hygiene: SMB/445 only, no legacy NetBIOS browsing on the LAN ---
   workgroup = WORKGROUP
   server string = {{ system_hostname | default('estia') }}
   disable netbios = yes
   smb ports = 445
   log file = /var/log/samba/log.%m
   max log size = 1000

[share]
   comment = {{ system_hostname | default('estia') }} <-> windows file exchange (Tailscale only)
   path = /srv/smbshare
   valid users = @smbshare
   read only = no
   browseable = yes
   # New files -> group-rw; new dirs -> group-rwx + setgid; all owned by the
   # smbshare group, so dimitrios (a member) can read/write them locally too.
   force group = smbshare
   create mask = 0660
   force create mode = 0660
   directory mask = 0770
   force directory mode = 2770
   inherit acls = yes
