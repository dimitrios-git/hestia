{
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true,
  "theme": "dark",
  "tui": "fullscreen",
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/srv/devshare"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pnpm:*)",
      "Bash(pnpx:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(corepack:*)",
      "Bash(yarn:*)",
      "Bash(turbo:*)",
      "Bash(python3:*)",
      "Bash(ansible-playbook * --check)",
      "Bash(ansible-playbook * --syntax-check)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(printenv:*)",
      "Bash(env:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(type:*)",
      "Bash(true:*)",
      "Bash(test:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(jq:*)",
      "Bash(diff:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(date:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git push * main)",
      "Bash(git push origin main)",
      "Bash(gh pr merge:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Read(.env*)",
      "Read(//**/.env*)"
    ]
  }
}
