#!/bin/bash
# start-sway — the Sway session launcher. greetd runs this via
# `tuigreet … --cmd start-sway` (see /etc/greetd/config.toml, which is still a manual
# step). It sets the Wayland session environment, then execs sway.
#
# The NVIDIA-specific workarounds are applied ONLY when an NVIDIA GPU is actually
# live (its kernel module is loaded / device node exists). That keeps this one script
# correct on AMD/Intel machines too — where GBM_BACKEND=nvidia-drm and
# __GLX_VENDOR_LIBRARY_NAME=nvidia would otherwise break rendering.
#
# Tracked at system/sway-session/start-sway.j2; RENDERED to /usr/local/bin/start-sway
# by the `sway_session` bootstrap role (the XCURSOR_THEME below follows `theme_variant`).
# Edit the tracked template + re-run the role to apply.

# --- generic Wayland session env (every GPU) ----------------------------------
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=sway
export XDG_CURRENT_DESKTOP=sway
export MOZ_ENABLE_WAYLAND=1
# NB: GTK_THEME is deliberately NOT exported. GTK3 apps follow the gsettings
# `gtk-theme` (hestia-dark/hestia) the theme fragment sets at login — gsettings is
# NOT ignored in a sway session (the old belief was a misdiagnosis: the launcher's
# former `GTK_THEME=Adwaita:dark` was *overriding* gsettings, masking it). Worse,
# a set GTK_THEME makes GTK4/libadwaita apps STOP following the portal color-scheme
# and render light (file-roller's Compress dialog was the live case). With GTK_THEME
# unset, GTK3 themes via gsettings and GTK4 via color-scheme — both dark, consistent.
# See docs/theming.md (GTK section).

# Mouse cursor for everything that reads Xcursor conventions (XWayland, Qt,
# SDL, …): KDE Breeze — white (Breeze_Light) on the dark desktop, standard
# Breeze on light. sway's own cursor + GTK get the same theme from the sway
# theme fragment (seat xcursor_theme + the gsettings exec) — keep in sync.
export XCURSOR_THEME={{ 'breeze_cursors' if theme_variant == 'light' else 'Breeze_Light' }}
export XCURSOR_SIZE=24

# Qt/KDE: point Qt at KDE's platform-theme plugin (plasma-integration) so Qt apps
# read ~/.config/kdeglobals — the rendered hestia scheme (qt_theme role). Without a
# platform theme, KDE apps that don't self-apply a scheme (dolphin, krusader — unlike
# kdenlive, which activates its ColorSchemePath itself) fall back to Qt's dark-Fusion
# palette with the stock blue highlight, ignoring kdeglobals entirely; bare-Qt apps
# get kdeglobals this way too (the once-deferred qt6ct track, resolved). Guarded on
# the plugin actually being installed — with the env set but the plugin absent, Qt
# logs a warning per launch and themes nothing.
if ls /usr/lib/*/qt6/plugins/platformthemes/KDEPlasmaPlatformTheme* >/dev/null 2>&1; then
    export QT_QPA_PLATFORMTHEME=kde
fi

# Make the SSH agent reachable by every app sway `exec`s (wofi launches, GUI git
# clients, IDEs pushing over ssh, …). The credential-unlock hook warms id_dimitrios
# into the agent at this deterministic socket; exporting the var HERE — before sway,
# and even before the socket exists — means GUI apps inherit it. Without this, the
# var only lives in ~/.bashrc, so terminal ssh works but sway-launched apps silently
# fall back to "no agent" (the bug behind the Zabbix-PWA launcher needing its own
# SSH_AUTH_SOCK line).
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/openssh_agent"

# --- NVIDIA-only workarounds (applied only when an NVIDIA GPU is in use) -------
sway_args=()
if [ -e /dev/nvidia0 ] || grep -qE '^nvidia ' /proc/modules 2>/dev/null; then
    export NVIDIA_DRIVER_CAPABILITIES=all
    export GBM_BACKEND=nvidia-drm
    export __GLX_VENDOR_LIBRARY_NAME=nvidia
    export WLR_NO_HARDWARE_CURSORS=1
    # Interim explicit-sync fix for the Chromium/Electron flicker + damage-only
    # ("squares under the cursor") repaints on NVIDIA. The base trixie driver (550)
    # lacks EGL_ANDROID_native_fence_sync, so wlroots' default GLES2 renderer can't do
    # explicit sync on it; the Vulkan renderer syncs through NVIDIA's (good) Vulkan
    # timeline semaphores instead, sidestepping the broken path — no driver change or
    # reboot, just a re-login. Once the driver is >= 555 (nvidia_backports, explicit sync
    # native on GLES2) this is redundant — comment it out then. If sway ever fails to
    # start with it set, drop to a VT (Ctrl+Alt+F2) and comment this line in
    # /usr/local/bin/start-sway (or re-render via the sway_session role) to recover.
    export WLR_RENDERER=vulkan
    # Escape hatches if a release misbehaves on NVIDIA (uncomment as needed):
    #export SWAY_IGNORE_NVIDIA=1
    #export XWAYLAND_NO_GLAMOR=1
    sway_args+=(--unsupported-gpu)
fi

exec sway "${sway_args[@]}"
