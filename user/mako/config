# mako — notification daemon. Behaviour lives here (direct-edit); colours live in
# the GENERATED theme-{dark,light}.conf pair (themes/hestia/render.py — edit
# palette.yml + re-render), symlinked by the bootstrap as theme.conf per
# `theme_variant`. Reload with `makoctl reload`.

border-radius=0
border-size=2
default-timeout=5000
max-visible=5
max-history=100
sort=-time
margin=8
padding=10,14

# Colours + the [urgency=high] section — included LAST so the fragment's section
# can't swallow keys in this file (everything after an include's [section] header
# would land inside it).
include=~/.config/mako/theme.conf
