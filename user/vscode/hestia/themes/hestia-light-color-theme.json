        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#005f00"
      }
    },
    {
      "name": "String escape / regex / interpolation",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "punctuation.section.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#5f00d7"
