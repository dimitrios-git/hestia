# RENDERED by Ansible (bootstrap `dotfiles` role) to ~/.gitconfig — NOT symlinked.
# Path generalisation (§5) + identity inputs (§6): gpg.program from {{ repo_root }};
# excludesfile uses git-native ~; identity (name/email/signing key) comes from the
# manifest/host_vars — `setup.sh` prompts for them. No signing key set → gpgsign
# off. Edit your host_vars (or `.j2`) and re-run the dotfiles role to apply.
[user]
	email = {{ git_user_email }}
	name = {{ git_user_name }}
	signingkey = {{ git_signingkey }}
[commit]
	gpgsign = {{ 'true' if git_signingkey else 'false' }}
[gpg]
	program = {{ repo_root }}/user/git/gpg-wrapper.sh
[init]
	defaultBranch = main
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = input
	editor = vim
# `git difftool -t vimdiff` (and any vimdiff difftool) launches vim with git's
# environment exported — including GIT_DIR / GIT_WORK_TREE pointing at the real
# repo. But difftool's buffers are temp blobs checked out under /tmp, OUTSIDE
# that work tree, so an in-editor git plugin (coc-git, fugitive, gitsigns…) that
# runs `git` on a buffer hits `fatal: <tmp>/file is outside repository` and
# reports e.g. "[coc.nvim] Failed to execute git" on every diffed file. Override
# the builtin vimdiff tool to wrap vim in `env -u GIT_DIR …` so the temp blobs
# resolve as "not a repo" and the plugins stay silent. The vim flags replicate
# git's own mergetools/vimdiff diff_cmd (-R -f -d, focus the HEAD window); the
# \" escapes keep $LOCAL/$REMOTE shell-quoted through git-config parsing (it
# strips bare double quotes), so paths with spaces survive.
[difftool "vimdiff"]
	cmd = env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE vim -R -f -d -c 'wincmd l' \"$LOCAL\" \"$REMOTE\"
{% if enable_claude_user | default(false) %}
# The shared collaboration tree ({{ claude_shared_tree | default('/srv/devshare') }}) is
# owned by the `claude` agent user, so git trips "dubious ownership" (CVE-2022-24765
# protection) when the human operates on those repos. Whitelist the whole tree with the
# git 2.36+ trailing-wildcard form — one entry covers every repo directly under it.
# Gated on enable_claude_user: no agent user → no claude-owned tree → nothing to allow.
# (claude_shared_tree is a claude_user-role default, out of scope here, hence the | default.)
[safe]
	directory = {{ claude_shared_tree | default('/srv/devshare') }}/*
{% endif %}

# --- hestia colours (wildcharm palette) ---------------------------------------
# Aligned to the bash prompt so the accent means ONE thing across both: the prompt
# shows the branch in yellow (#d78700) and the dirty counts (!N/?N) in the accent
# (#d7005f). So here too: branch = yellow, staged/added = green, dirty
# (changed/untracked) = accent. Diff lines stay clean red/green (line-level, off
# the accent — git's default `old`=red would otherwise be color1 == #d7005f).
# git 2.26+ renders #hex as 24-bit truecolor; values with '#' must be quoted.
[color]
	ui = auto
[color "branch"]
	current = "#d78700 bold"   ; yellow — match the prompt's branch
	remote = "#767676"         ; dim (remote-tracking)
	upstream = "#00afaf"       ; cyan
[color "status"]
	branch = "#d78700 bold"    ; yellow — match the prompt's branch
	header = "#767676"         ; dim
	added = "#00af5f"          ; staged → green (match prompt +N)
	changed = "#d7005f"        ; unstaged → accent (match prompt !N)
	untracked = "#d7005f"      ; untracked → accent (match prompt ?N)
	nobranch = "#d7005f bold"  ; accent (attention)
[color "diff"]
	meta = "#767676 bold"      ; the "diff --git" header, de-emphasised
	frag = "#00afaf"           ; @@ hunk headers (cyan)
	func = "#9e9e9e"           ; function/context line (muted)
	old = "#ff5f87"            ; removed → clean bright red (line-level, off accent)
	new = "#00d75f"            ; added → bright green
	commit = "#ffaf00"         ; commit hash lines (yellow)
	whitespace = "#ff5f87 reverse"
[color "decorate"]
	branch = "#d78700 bold"    ; yellow — local branch in `git log --decorate`
	remoteBranch = "#767676"   ; dim
	tag = "#ffaf00"            ; bright yellow
	stash = "#d787d7"          ; magenta
	HEAD = "#00d7d7 bold"      ; cyan — the "you are here" marker
	grafted = "#767676"
