# cmus startup commands — sourced after cmus restores saved options, so these win.
# hestia-matched theme; the accent is VIOLET (0.10.0 — the red→violet flip; cmus
# is 256-colour, no truecolor, so it uses the nearest cube violets, NOT ANSI
# colour 1, which stays red). Two accent uses, split for legibility since no one
# cube violet works as both: FILLS (titleline/progress/playing-track bg + white
# 231) = 56 (#5f00d7, white-on 7.33) in both variants; accent TEXT (info, playing
# track fg) = 141 (#af87ff) on dark / 56 on light, so it stays readable on the
# ground. The other ABSOLUTE 256-cube indices (greys, error, dir blue) are
# dark-tuned and flip with `theme_variant` (M7), mirroring the vifm colorscheme.
#
# RENDERED by Ansible (bootstrap `dotfiles` role) to ~/.config/cmus/rc — NOT
# symlinked. The music-library path is host-specific data (not a config/home path),
# so it comes from `cmus_music_dir` (default ~/Music; override per host in
# bootstrap/host_vars/<host>.yml). Path generalisation — docs/repo-structure-design.md §5.
{% if theme_variant == 'light' %}

# command / messages
set color_cmdline_bg=-1
set color_cmdline_fg=234
set color_error=160
set color_info=56
set color_separator=249

# status line (bottom) — dark text on a light raised bar (surface 254)
set color_statusline_bg=254
set color_statusline_fg=234
set color_statusline_progress_bg=56
set color_statusline_progress_fg=231

# title line (top, now-playing bar)
set color_titleline_bg=56
set color_titleline_fg=231

# browser / library windows
set color_win_bg=-1
set color_win_fg=234
set color_win_dir=25
set color_win_cur=56
set color_win_title_bg=56
set color_win_title_fg=231

# selections — active cursor is the dark-grey bar 59 (#5f5f5f, matching vifm's
# light cursor line) with bold white text; accent violet for the playing track;
# lighter greys (255/254) for the inactive window so it reads as unfocused.
set color_win_sel_bg=59
set color_win_sel_fg=231
set color_win_sel_attr=bold
set color_win_cur_sel_bg=56
set color_win_cur_sel_fg=231
set color_win_inactive_sel_bg=255
set color_win_inactive_sel_fg=234
set color_win_inactive_cur_sel_bg=254
set color_win_inactive_cur_sel_fg=234
{% else %}

# command / messages
set color_cmdline_bg=-1
set color_cmdline_fg=253
set color_error=204
set color_info=141
set color_separator=240

# status line (bottom) — light text on dark bg for readability
set color_statusline_bg=236
set color_statusline_fg=253
set color_statusline_progress_bg=56
set color_statusline_progress_fg=231

# title line (top, now-playing bar)
set color_titleline_bg=56
set color_titleline_fg=231

# browser / library windows
set color_win_bg=-1
set color_win_fg=253
set color_win_dir=39
set color_win_cur=141
set color_win_title_bg=56
set color_win_title_fg=231

# selections — active cursor uses the brighter grey 247 (#9e9e9e, matching vifm's
# cursor line) with bold dark text; accent violet for the playing track; dimmer greys
# for the inactive window so it still reads as unfocused.
set color_win_sel_bg=247
set color_win_sel_fg=16
set color_win_sel_attr=bold
set color_win_cur_sel_bg=56
set color_win_cur_sel_fg=231
set color_win_inactive_sel_bg=235
set color_win_inactive_sel_fg=253
set color_win_inactive_cur_sel_bg=236
set color_win_inactive_cur_sel_fg=253
{% endif %}

# Open the file browser (view 5) here by default
cd {{ cmus_music_dir }}

# U = rescan the music folder for newly added tracks (library dedupes, so it's
# safe to repeat). Overrides the rarely-used win-update-cache default.
# (u still = update-cache: prune deleted / refresh changed tags.)
bind -f common U add -l {{ cmus_music_dir }}
