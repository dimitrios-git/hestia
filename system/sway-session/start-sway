#!/bin/bash
# start-sway — the Sway session launcher. greetd runs this via
# `tuigreet … --cmd start-sway` (see /etc/greetd/config.toml, which is still a manual
# step). It sets the Wayland session environment, then execs sway.
#
# The NVIDIA-specific workarounds are applied ONLY when an NVIDIA GPU is actually
# live (its kernel module is loaded / device node exists). That keeps this one script
# correct on AMD/Intel machines too — where GBM_BACKEND=nvidia-drm and
# __GLX_VENDOR_LIBRARY_NAME=nvidia would otherwise break rendering.
#
# Tracked at system/sway-session/start-sway; deployed to /usr/local/bin/start-sway by
# the `sway_session` bootstrap role. Edit the tracked copy + re-run the role to apply.

# --- generic Wayland session env (every GPU) ----------------------------------
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=sway
export XDG_CURRENT_DESKTOP=sway
export MOZ_ENABLE_WAYLAND=1
# Force the estia GTK3 theme session-wide. GTK_THEME is the HIGHEST-priority theme
# source — it overrides gsettings org.gnome.desktop.interface gtk-theme AND
# ~/.config/gtk-3.0/settings.ini — so in-process GTK3 apps (Remmina, GIMP, etc.) in a
# non-GNOME sway session pick the theme up from here, not from those files. estia-dark is
# the recoloured adw-gtk3 built by the gtk_theme role (#ce0056 accent). libadwaita apps
# ignore GTK_THEME (their accent is locked on 1.7 — see docs/theming.md).
export GTK_THEME=estia-dark

# Make the SSH agent reachable by every app sway `exec`s (wofi launches, GUI git
# clients, IDEs pushing over ssh, …). The credential-unlock hook warms id_dimitrios
# into the agent at this deterministic socket; exporting the var HERE — before sway,
# and even before the socket exists — means GUI apps inherit it. Without this, the
# var only lives in ~/.bashrc, so terminal ssh works but sway-launched apps silently
# fall back to "no agent" (the bug behind the Zabbix-PWA launcher needing its own
# SSH_AUTH_SOCK line).
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/openssh_agent"

# --- NVIDIA-only workarounds (applied only when an NVIDIA GPU is in use) -------
sway_args=()
if [ -e /dev/nvidia0 ] || grep -qE '^nvidia ' /proc/modules 2>/dev/null; then
    export NVIDIA_DRIVER_CAPABILITIES=all
    export GBM_BACKEND=nvidia-drm
    export __GLX_VENDOR_LIBRARY_NAME=nvidia
    export WLR_NO_HARDWARE_CURSORS=1
    # Escape hatches if a release misbehaves on NVIDIA (uncomment as needed):
    #export SWAY_IGNORE_NVIDIA=1
    #export XWAYLAND_NO_GLAMOR=1
    sway_args+=(--unsupported-gpu)
fi

exec sway "${sway_args[@]}"
