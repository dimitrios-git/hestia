{
    "layer": "top",
    "position": "top",
    "height": 32,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["tray", "custom/cpu", "memory", "custom/gpu0", "custom/gpu1", "custom/gpu2", "power-profiles-daemon", "pulseaudio", "sway/language", "network", "bluetooth", "custom/usb", "custom/notifications", "custom/weather", "clock", "custom/debian"],

    "custom/gpu0": {
        "format": "<span size='xx-large' rise='-3072'>󰢮</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/gpu.sh 0",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-gpu && swaymsg '[app_id=\"^floatterm-gpu$\"] kill' || kitty --class floatterm-gpu -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/gpu-watch.sh"
    },
    "custom/gpu1": {
        "format": "<span size='xx-large' rise='-3072'>󰢮</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/gpu.sh 1",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-gpu && swaymsg '[app_id=\"^floatterm-gpu$\"] kill' || kitty --class floatterm-gpu -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/gpu-watch.sh"
    },
    "custom/gpu2": {
        "format": "<span size='xx-large' rise='-3072'>󰢮</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/gpu.sh 2",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-gpu && swaymsg '[app_id=\"^floatterm-gpu$\"] kill' || kitty --class floatterm-gpu -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/gpu-watch.sh"
    },

    "power-profiles-daemon": {
        "format": "<span size='xx-large' rise='-3072'>{icon}</span>",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "󰓅",
            "performance": "󰓅",
            "balanced": "󰾅",
            "power-saver": "󰌪"
        }
    },

    "bluetooth": {
        "format": "<span size='x-large' rise='-2560'>󰂯</span>",
        "format-disabled": "<span size='x-large' rise='-2560'>󰂲</span>",
        "format-off": "<span size='x-large' rise='-2560'>󰂲</span>",
        "format-connected": "<span size='x-large' rise='-2560'>󰂱</span> {num_connections}",
        "tooltip-format": "{controller_alias}\t{status}",
        "tooltip-format-connected": "{controller_alias}\t{status}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "pgrep -x bluetuith >/dev/null && pkill -x bluetuith || kitty --class floatterm -e bluetuith",
        "on-click-right": "rfkill toggle bluetooth"
    },

    "network": {
        "format-wifi": "<span size='xx-large' rise='-3072'>󰖩</span> {signalStrength:>3}%",
        "format-ethernet": "<span size='xx-large' rise='-3072'>󰈀</span>",
        "format-disconnected": "<span size='xx-large' rise='-3072'>󰖪</span>",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "pgrep -x nmtui >/dev/null && pkill -x nmtui || kitty --class floatterm -e nmtui"
    },

    "sway/language": {
        "format": "<span size='xx-large' rise='-3072'>󰗊</span> {short}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },


    "sway/workspaces": {
        "disable-scroll": true
    },

    "custom/cpu": {
        "format": "<span size='xx-large' rise='-3072'>󰻠</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/cpu.sh",
        "on-click": "pgrep -x htop >/dev/null && pkill -x htop || kitty --class floatterm -e htop"
    },

    "memory": {
        "format": "<span size='xx-large' rise='-3072'>󰍛</span> {used:>4.1f}G",
        "interval": 2,
        "tooltip-format": "RAM  {used:0.1f} / {total:0.1f} GiB ({percentage}%)\nfree {avail:0.1f} GiB · swap {swapUsed:0.1f} / {swapTotal:0.1f} GiB",
        "on-click": "pgrep -x htop >/dev/null && pkill -x htop || kitty --class floatterm -e htop"
    },

    "pulseaudio": {
        "format": "<span size='xx-large' rise='-3072'>󰕾</span> {volume:>3}%",
        "format-muted": "<span size='xx-large' rise='-3072'>󰖁</span> muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pgrep -x pulsemixer >/dev/null && pkill -x pulsemixer || kitty --class floatterm -e pulsemixer"
    },

    "clock": {
        "format": "<span size='xx-large' rise='-3072'></span> {:%Y-%m-%d %H:%M:%S %Z}",
        "interval": 1,
        "tooltip-format": "{:%A, %d %B %Y}\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#ce0056'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click": "shift_reset",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "custom/usb": {
        "format": "<span size='xx-large' rise='-3072'>󰪒</span> {}",
        "return-type": "json",
        "interval": 5,
        "exec": "$HOME/.config/waybar/scripts/usb.sh",
        "on-click": "$HOME/.config/waybar/scripts/usb.sh menu"
    },

    "custom/notifications": {
        "format": "<span size='xx-large' rise='-3072'>󰂜</span>",
        "tooltip": "Notification history (click)",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-notify && swaymsg '[app_id=\"^floatterm-notify$\"] kill' || kitty --class floatterm-notify -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/notifications.sh show"
    },

    "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "interval": 1800,
        "exec": "$HOME/.config/waybar/scripts/weather.sh",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-weather && swaymsg '[app_id=\"^floatterm-weather$\"] kill' || kitty --class floatterm-weather -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/weather.sh show"
    },

    "custom/debian": {
        "format": "<span size='xx-large' rise='-3072'></span>",
        "tooltip": false
    },

    "tray": {
        "spacing": 10
    }
}
