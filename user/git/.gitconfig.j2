# RENDERED by Ansible (bootstrap `dotfiles` role) to ~/.gitconfig — NOT symlinked.
# Path generalisation (§5) + identity inputs (§6): gpg.program from {{ repo_root }};
# excludesfile uses git-native ~; identity (name/email/signing key) comes from the
# manifest/host_vars — `setup.sh` prompts for them. No signing key set → gpgsign
# off. Edit your host_vars (or `.j2`) and re-run the dotfiles role to apply.
[user]
	email = {{ git_user_email }}
	name = {{ git_user_name }}
	signingkey = {{ git_signingkey }}
[commit]
	gpgsign = {{ 'true' if git_signingkey else 'false' }}
[gpg]
	program = {{ repo_root }}/user/git/gpg-wrapper.sh
[init]
	defaultBranch = main
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = input
	editor = vim
[merge]
	# 3-way conflict resolution in Neovim. `git mergetool` opens each conflicted
	# file as three vertical windows — LOCAL (ours) | MERGED (the working file =
	# the RESULT you edit) | REMOTE (theirs). Resolve by pulling hunks into the
	# middle buffer (nvim :diffget, or `do`/`dp`), then `:wqa`. Needs neovim
	# (the `neovim` apt package, which the manifest installs). editor stays vim;
	# only the merge tool is nvim, for its 3-way diff view.
	tool = nvimdiff
	# zdiff3 (git 2.35+) keeps the common-ancestor lines inside the conflict
	# markers (|||||||). The LOCAL,MERGED,REMOTE layout below shows no separate
	# BASE window, so this is where you still see what each side changed FROM.
	conflictstyle = zdiff3
[mergetool "nvimdiff"]
	# git's built-in nvimdiff default is a 4-pane (LOCAL,BASE,REMOTE)/MERGED.
	# Override to the 3-pane local | result | remote the "nvimdiff2" preset uses,
	# spelled out so it's self-documenting (see `git help mergetool`).
	layout = LOCAL,MERGED,REMOTE
[mergetool]
	# Launch straight into nvim per conflicted file — no "Hit return to start" prompt.
	prompt = false
	# Don't leave <file>.orig backups behind after a successful resolve.
	keepBackup = false
{% if enable_claude_user | default(false) %}
# The shared collaboration tree ({{ claude_shared_tree | default('/srv/devshare') }}) is
# owned by the `claude` agent user, so git trips "dubious ownership" (CVE-2022-24765
# protection) when the human operates on those repos. Whitelist the whole tree with the
# git 2.36+ trailing-wildcard form — one entry covers every repo directly under it.
# Gated on enable_claude_user: no agent user → no claude-owned tree → nothing to allow.
# (claude_shared_tree is a claude_user-role default, out of scope here, hence the | default.)
[safe]
	directory = {{ claude_shared_tree | default('/srv/devshare') }}/*
{% endif %}

# --- hestia colours (from palette.yml) ---------------------------------------
# Aligned to the bash prompt so attention reads ONE way across both: the prompt
# shows the branch in yellow (#d78700) and the dirty counts (!N/?N) in the
# attention red (#d70000 — the hestia red / color1, NOT the violet accent). So
# here too: branch = yellow, staged/added = green, dirty (changed/untracked) =
# red. Diff lines stay clean red/green (line-level; git's default `old`=red is
# color1 == #d70000).
# git 2.26+ renders #hex as 24-bit truecolor; values with '#' must be quoted.
[color]
	ui = auto
[color "branch"]
	current = "#d78700 bold"   ; yellow — match the prompt's branch
	remote = "#767676"         ; dim (remote-tracking)
	upstream = "#00afaf"       ; cyan
[color "status"]
	branch = "#d78700 bold"    ; yellow — match the prompt's branch
	header = "#767676"         ; dim
	added = "#00af5f"          ; staged → green (match prompt +N)
	changed = "#d70000"        ; unstaged → attention red (match prompt !N)
	untracked = "#d70000"      ; untracked → attention red (match prompt ?N)
	nobranch = "#d70000 bold"  ; attention red (the accent is now violet; red kept for attention, per the split)
[color "diff"]
	meta = "#767676 bold"      ; the "diff --git" header, de-emphasised
	frag = "#00afaf"           ; @@ hunk headers (cyan)
	func = "#9e9e9e"           ; function/context line (muted)
	old = "#ff5f87"            ; removed → clean bright red (line-level, off accent)
	new = "#00d75f"            ; added → bright green
	commit = "#ffaf00"         ; commit hash lines (yellow)
	whitespace = "#ff5f87 reverse"
[color "decorate"]
	branch = "#d78700 bold"    ; yellow — local branch in `git log --decorate`
	remoteBranch = "#767676"   ; dim
	tag = "#ffaf00"            ; bright yellow
	stash = "#d787d7"          ; magenta
	HEAD = "#00d7d7 bold"      ; cyan — the "you are here" marker
	grafted = "#767676"
