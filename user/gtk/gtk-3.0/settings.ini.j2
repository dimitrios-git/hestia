# GTK 3 settings — RENDERED from settings.ini.j2 by the dotfiles role (the theme name
# follows `theme_variant`). The hestia/hestia-dark themes (recoloured adw-gtk3,
# installed by the gtk_theme role) carry the base + #7c3aed accent. This covers
# non-portal GTK3 apps; the portal file chooser reads the theme from gsettings instead
# (set at login by sway's theme fragment). See docs/theming.md.
[Settings]
gtk-theme-name=hestia{{ '' if theme_variant == 'light' else '-dark' }}
gtk-application-prefer-dark-theme={{ '0' if theme_variant == 'light' else '1' }}
# Yaru-hestia = the #7c3aed-accent Yaru icon theme built by the (opt-in) yaru_icons
# role. Absent on a spin without that role -> GTK falls back to a default icon theme.
gtk-icon-theme-name=Yaru-hestia
# Breeze cursors (breeze-cursor-theme, apt) — white on the dark desktop, the
# standard dark Breeze on light; gsettings + XCURSOR_THEME carry the same pick.
gtk-cursor-theme-name={{ 'breeze_cursors' if theme_variant == 'light' else 'Breeze_Light' }}
gtk-cursor-theme-size=24
