" vim: ft=vim

" General

colorscheme hestia

set vicmd=vim
set trash
set trashdir=~/.local/share/Trash/files
set history=100
set followlinks
set sortnumbers
set undolevels=100
set vimhelp
set norunexec
set timefmt='%Y/%m/%d %H:%M'
set wildmenu
set wildstyle=popup
set ignorecase
set smartcase
set nohlsearch
set incsearch
set scrolloff=4

" Mouse: let vifm handle wheel events itself so one tick scrolls ONE line.
" Without this vifm doesn't grab the mouse ('mouse' defaults to ""), so the
" terminal (kitty) synthesises fake arrow-keys per wheel tick — and kitty's
" wheel_scroll_multiplier default is 5.0, i.e. 5 files/tick. With mouse on,
" vifm binds <ScrollWheelDown>=<c-e> / <ScrollWheelUp>=<c-y> (scroll the view
" by a single line), giving the wanted 1-file/tick — and scoped to vifm, so
" kitty's scrollback speed elsewhere is untouched. (Terminal text selection
" now needs Shift-drag, the usual TUI-with-mouse trade-off, as in vim.)
set mouse=a

" Export THIS instance's server name for the imv-browse/return scripts: their
" `vifm --remote` calls must drive the panes of the vifm that launched imv —
" a bare --remote reaches the FIRST server (name "vifm"), so with several
" vifm instances open, Enter-on-image in a later one collapsed the WRONG
" window's panes (seen live as "the preview pane no longer hides"; the miller
" commit was coincidental timing). vifm doesn't export this by itself;
" children inherit env vars set with :let.
let $VIFM_SERVER_NAME = v:servername

" Show a live preview of the selected file in the other (right) pane on startup.
" `w` (mapped below) toggles it off/on. `view!` is idempotent — it ensures quick
" view is ON rather than toggling, so it sticks when vifmrc runs at launch.
view!

" Miller columns (ranger/yazi-inspired, 2026-07): a slim parent-context column
" on the left of the browsing pane, so with the quick view above the layout
" reads as the ranger triple — parent | current | preview. rsize:0 disables
" miller's OWN in-pane preview column: the quick-view pane already previews
" everything through preview.sh (directories included, as a tree), so a right
" miller column would just double it up. Options BEFORE the toggle, so the view
" comes up sized correctly.
set milleroptions=lsize:1,csize:2,rsize:0
set millerview

" Marks

mark h ~/
mark D ~/Downloads/
mark d ~/Documents/
mark c ~/.config/
mark v ~/Videos/
mark p ~/Pictures/

" File associations (filextype = Wayland/X11 GUI apps)

" Images — Enter/l opens the integrated imv browser (imv-browse.sh): collapse
" vifm to one pane + tile imv to the RIGHT on the folder's images (config-vifm:
" live cursor sync on j/k, q returns). Idempotent — opening another image while
" imv is up just jumps the open imv to it (imv-msg goto) and focuses, instead of
" stacking a second pane. imv-browse.sh drives vifm's panes via `vifm --remote`,
" so it works from this shell handler (unlike an in-keybind :only). Full design:
" CLAUDE.md "vifm↔imv integrated image browsing".
filextype {*.jpg,*.jpeg,*.png,*.gif,*.bmp,*.tiff,*.tif,*.webp,*.avif,*.ico,*.svg}
        \ imv-browse.sh %c:p %d &

" Video — opens the SAME integrated imv browser as images (imv-browse.sh): the
" folder's videos appear as ▶ poster thumbnails alongside images, browsed with
" j/k; Enter on a video promotes it to mpv. (Direct play is still `mpv` via the
" {mpv} :file menu entry / the audio fallback.)
filextype {*.avi,*.mp4,*.wmv,*.dat,*.3gp,*.ogv,*.mkv,*.mpg,*.mpeg,*.vob,
          \*.m2v,*.mov,*.flv,*.ts,*.webm,*.m4v,*.m4b}
        \ imv-browse.sh %c:p %d &

" Audio — play in cmus (falls back to mpv --no-video if cmus isn't running)
filetype {*.wav,*.mp3,*.flac,*.ogg,*.m4a,*.opus,*.aac,*.wv}
       \ {Play in cmus} sh -c 'if pgrep -u "$USER" -x cmus >/dev/null; then cmus-remote -f "$@"; else mpv --no-video "$@"; fi' _ %f,
       \ {Queue in cmus} cmus-remote -q %f,
       \ {mpv (no video)} mpv --no-video %f

" Markdown — render in glow (TUI pager); falls back to editing in vim.
" -w wraps at the real terminal width (glow's built-in default caps at 80 cols
" even on a wide terminal). The -2 is glamour's 2-col document left margin:
" tables are sized to the wrap width then indented by it, so at exactly
" $(tput cols) the table border overruns by 2 and wraps — subtract it.
filetype {*.md,*.markdown}
       \ {Render in glow} glow -w $(($(tput cols) - 2)) -p %f,
       \ {Edit in vim} vim %f

" PDF
filextype {*.pdf}
        \ zathura %f 2>/dev/null &,
        \ mupdf %f 2>/dev/null &

" epub / djvu / comic books — all handled by zathura plugins
filextype {*.epub,*.djvu,*.cbr,*.cbz}
        \ zathura %f 2>/dev/null &

" Office documents
filextype {*.odt,*.ods,*.odp,*.docx,*.doc,*.xlsx,*.xls,*.pptx,*.ppt}
        \ libreoffice %f &

" Archives — list contents
filetype {*.tar.gz,*.tgz,*.tar.bz2,*.tbz2,*.tar.xz,*.txz,*.tar.zst}
       \ {View} tar tf %f | less
filetype {*.zip}
       \ {View} unzip -l %f | less,
       \ {Extract} unzip %f
filetype {*.rar}
       \ {View} unrar l %f | less,
       \ {Extract} unrar x %f
filetype {*.7z}
       \ {View} 7z l %f | less,
       \ {Extract} 7z x %f

" Preview pane (toggle with w)

" Images — text info only (mediainfo: dimensions, format, colour depth). In-pane
" image *rendering* was tried TWICE and dropped both times: chafa sixels /
" kitty icat never displayed in vifm's pane and lagged scrolling; viu's ANSI
" half-blocks (2026-07, image-viewer evaluation) DID render and were fast, but
" a ~60x60-pixel block mosaic wasn't worth replacing the info text for (the
" verdict: not the ASCII look hoped for). Press Enter to open the actual image
" in imv — fast, separate window (filextype above).
fileviewer {*.jpg,*.jpeg,*.png,*.gif,*.bmp,*.tiff,*.webp,*.avif,*.svg,*.ico}
         \ mediainfo %f

" Markdown — NO dedicated previewer: .md falls through to the catch-all `bat`
" viewer below (syntax-highlighted SOURCE + line numbers). A glow *render* in the
" pane was tried and dropped (2026-07): forced through a notty pipe glow is
" 16-colour only and its line-wrapping/width offset never sat right in the pane,
" so the render looked worse than clean source. Instead the hestia bat theme now
" COLOURS markdown source to mirror glow — H1 violet, H2–H6 cyan, `code`/links
" violet (themes/hestia/scopes.yml markup.* rules) — so the bat preview reads on
" the same palette as the glow OPEN (`:file` → glow -p, real TTY, truecolor).

" PDF — requires poppler-utils
fileviewer {*.pdf}
         \ pdftotext -l 10 -nopgbrk %f - 2>/dev/null

" Audio / video metadata — requires mediainfo
fileviewer {*.mp4,*.mkv,*.avi,*.mov,*.webm,*.flv,*.mp3,*.flac,*.ogg,*.m4a,*.opus}
         \ mediainfo %f

" Archives
fileviewer {*.tar.gz,*.tgz,*.tar.bz2,*.tbz2,*.tar.xz,*.txz}
         \ tar tf %f
fileviewer {*.zip}
         \ unzip -l %f
fileviewer {*.7z}
         \ 7z l %f

" Everything else — syntax-highlighted code/text preview via bat (hestia
" theme), with a binary/directory fallback. Catch-all goes LAST so the specific
" viewers above win (vifm uses the first matching :fileviewer). preview.sh lives
" in ~/.config/vifm/scripts (on vifm's PATH); %pw/%ph size output to the pane.
" Uses %c:p (current file, full path), NOT %f: on the ".." parent entry vifm
" expands %f to NOTHING, so the args shift left (%pw lands in $1) and preview.sh
" ran `file` on the pane width — the `cannot open '48'` error. %c:p always yields
" one absolute path (".." resolves to the parent dir), so args never shift and
" hovering ".." previews the parent's listing (preview.sh's -d branch).
fileviewer {*}
         \ preview.sh %c:p %pw %ph

" Key bindings

" Open shell in current directory
nnoremap s :shell<cr>

" Toggle preview pane
nnoremap w :view<cr>
vnoremap w :view<cr>gv

" Sort dialog
nnoremap S :sort<cr>

" Yank current dir/file path to Wayland clipboard (requires wl-clipboard)
nnoremap yd :!echo -n %d | wl-copy<cr>
nnoremap yf :!echo -n %c:p | wl-copy<cr>

" Open with xdg-open as fallback
nnoremap o :!xdg-open %f &<cr>

" Custom commands (:name [args])

" git: diff the file under the cursor against a branch, in vimdiff — short for
" the verbose `git difftool -y -t vimdiff master...HEAD -- <file>`.
"   :gd        vs the default branch's merge-base with HEAD; base auto-detected
"              (main, else master) so the same command works in either repo.
"   :gd <ref>  vs <ref> instead, e.g. :gd origin/main, :gd develop, :gd HEAD~3.
" The file is taken automatically (the cursor file) — do NOT pass it; the
" optional argument (%a) is only the base ref. An unknown base ref (e.g. a
" filename typed by mistake) is rejected with a clear message rather than git's
" cryptic `bad revision`. Foreground — vifm suspends until you :qa out of vim.
"
" Works from a normal listing AND from :gc's custom view. It resolves the cursor
" file by FULL path (%c:p) → repo root + repo-relative path, and runs every git
" op with `git -C` anchored to the file's own directory. It must NOT rely on
" vifm's cwd + basename (`git show HEAD:./<name>`): in a :gc custom view the cwd
" is wherever you launched :gc (e.g. the repo root) while the file is in a subdir,
" so `./<name>` doesn't exist there and both blobs come out EMPTY — the bug that
" showed two blank vimdiff panes when running :gd on a :gc entry. The %c:p macro
" is UNQUOTED (`fp=%c:p`, like the old `f=%c:t`): vifm does NOT expand a macro
" wrapped in single quotes (`'%c:p'` → empty), so don't add quotes around it.
"
" It does NOT use `git difftool`: difftool only launches the tool for files that
" actually differ, so on an unmodified file it would just flash and do nothing.
" Instead it extracts both sides itself — the merge-base blob (`$mb:$rel`) and
" the HEAD blob — into a temp dir and opens `vim -d` on them, so :gd ALWAYS
" opens a diff view: changed files show the diff, unmodified files show two
" identical panes, a file new on the branch shows added-vs-empty. The temp
" blobs live under /tmp, outside any repo, so in-editor git plugins (coc-git,
" fugitive…) see "not a repo" and stay quiet — no GIT_DIR inheritance like the
" difftool path had. Missing side (added/deleted) → empty file. Flags mirror
" git's builtin vimdiff (-R -d, focus the HEAD pane).
command! gd !fp=%c:p; wd=$(dirname "$fp"); git -C "$wd" rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "gd: not inside a git repository"; exit 1; }; root=$(git -C "$wd" rev-parse --show-toplevel); rel=${fp#"$root"/}; name=$(basename "$fp"); b='%a'; [ -z "$b" ] && b=$(git -C "$wd" rev-parse -q --verify main >/dev/null 2>&1 && echo main || echo master); git -C "$wd" rev-parse -q --verify "$b" >/dev/null 2>&1 || { echo "gd: unknown base ref '$b' (:gd takes the file automatically; the optional arg is a base ref like origin/main)"; exit 1; }; mb=$(git -C "$wd" merge-base "$b" HEAD 2>/dev/null || echo "$b"); t=$(mktemp -d) || exit 1; mkdir -p "$t/base" "$t/head"; git -C "$root" show "$mb:$rel" > "$t/base/$name" 2>/dev/null || : > "$t/base/$name"; git -C "$root" show "HEAD:$rel" > "$t/head/$name" 2>/dev/null || : > "$t/head/$name"; vim -R -d -c "wincmd l" "$t/base/$name" "$t/head/$name"; rm -rf "$t"

" git: find the files this branch changed vs main (what Claude edited in a PR you
" checked out). Both take an optional base ref (%a) like :gd — default main, else
" master; three-dot BASE...HEAD = changes since the branch forked. The shell
" pipeline lives in user/vifm/scripts/git-changed.sh (vifm parses a literal `|`
" in a :command / :select as a command separator, so it can't be inline here).
"
"   :gc  (key gc) — jump list. Populates a custom view (%U) with just the changed
"        files as a flat list; j/k to move, Enter opens. To LEAVE the view: `gh`
"        (key, or the :gh command below) returns to where you opened :gc; `gr`
"        jumps to the repo root. Best for "open what changed, directly".
"   :gs  (key gs) — inline highlight. :select-marks the changed files AND the
"        folders leading to them (--dirs) right in the normal browser, so at the
"        repo root both `CLAUDE.md` and `bootstrap/` light up; descend and the
"        trail continues. Re-run after moving (see the auto note below).
"
" Auto-highlight on directory entry was tried (autocmd DirEnter :gs) and does NOT
" work: vifm clears the pane selection as part of loading a directory, so the
" autocmd's selection never sticks (verified — even a static :select evaporates).
" The `gs` key is the practical substitute: one press after you land in a repo.
"
" Caveat: :gs reuses vifm's SELECTION, which is also the target of file ops (dd,
" yy, …). After :gs the highlighted (changed) files are what those act on until
" you clear the selection (Esc, or space to toggle) — intentional, just be aware.
command! gc !git-changed.sh %a %U
command! gs :select !git-changed.sh --dirs %a
nnoremap gc :gc<cr>
nnoremap gs :gs<cr>

" git: cd to the repository root (key gr). Handy on its own, and the tidy way out
" of the :gc jump list — after browsing the changed files, `gr` drops you back to
" normal browsing at the repo top instead of some subdir. Uses vifm's expression
" `cd`: system() runs `git rev-parse --show-toplevel`, `tr -d` strips the trailing
" newline IN THE SHELL (vifm 0.14 has no trim()/substitute() — only system() and
" fnameescape()), and fnameescape() quotes the path for the :cd. The `|| echo .`
" makes it a true no-op outside a git repo (`:cd .` stays put) — without it an
" empty result would send `:cd` to $HOME (vifm's no-arg :cd behaviour).
command! gr :execute 'cd' fnameescape(system('(git rev-parse --show-toplevel 2>/dev/null || echo .) | tr -d "\n"'))
nnoremap gr :gr<cr>

" git: leave the :gc jump list (:gh, mirrors vifm's built-in `gh` KEY). `gh` is a
" built-in key, not a command — so typing `:gh` alongside :gc/:gs/:gr/:gd got
" "Invalid command name". This aliases it: :norm[al]! runs the `gh` key, whose
" custom-view meaning is "return to the original directory" (where you opened
" :gc); in a normal listing it's plain "go up one directory". The key itself is
" unchanged (this only ADDS the :gh command; it does not remap the key).
command! gh :normal! gh
