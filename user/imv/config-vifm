# imv config for vifm's image/video browse (filextype → imv-browse.sh). Videos
# appear as ▶ poster thumbnails; Enter on one opens mpv.
#
# vifm's `i` (image-browse) launches imv with `imv_config` pointed here, so the
# normal standalone imv config (user/imv/config) is left untouched. Same
# navigation binds as that config; the difference is what `q` (and Escape) do on
# the way out: they talk back to the vifm that spawned imv via `vifm --remote` —
#   1. restore vifm's panes (the launch collapsed it with :only),
#   2. move vifm's cursor onto the last image viewed — :goto SELECTS without
#      opening (plain `vifm --remote <file>` would OPEN it and relaunch imv),
# then close imv. `vifm --remote` no-ops when no vifm server is running, so this
# config is harmless if ever used standalone. (Paths are single-quoted for
# vifm's command parser so spaces in filenames survive.)

[options]
fullscreen = false
scaling_mode = shrink

[binds]
# LIVE cursor sync: each move advances imv, then `exec`s the
# return script (no arg), which nudges vifm's cursor onto the now-current image
# (--remote :goto — selects, doesn't open). NOTE the `;` has NO space before it:
# imv's INI parser strips `<space>;…` as an inline comment, so `next 1 ; exec …`
# silently dropped the exec — `next 1;exec …` survives to imv's command splitter.
# Routed through the script (not inline) since inline shell quoting also mangles.
# If this lags fast scrolling, drop the `;exec …` tails for sync-on-quit only.
j = next 1;exec $HOME/.config/imv/imv-vifm-return.sh
k = prev 1;exec $HOME/.config/imv/imv-vifm-return.sh
l = next 1;exec $HOME/.config/imv/imv-vifm-return.sh
n = next 1;exec $HOME/.config/imv/imv-vifm-return.sh
N = prev 1;exec $HOME/.config/imv/imv-vifm-return.sh
p = prev 1;exec $HOME/.config/imv/imv-vifm-return.sh
# h = up/back, vim-style: close imv and take vifm UP one directory (cursor lands
# on the folder you were in). j/k/l/n/N/p still cycle items; prev is on k.
h = exec $HOME/.config/imv/imv-vifm-return.sh up
# Enter on a VIDEO (shown as a ▶ thumbnail) promotes it to mpv; on an image it
# does nothing (you're already viewing it). The return script resolves which via
# imv's $imv_current_index + the session map.
<Return> = exec $HOME/.config/imv/imv-vifm-return.sh play

# pan when zoomed in (no sync — same file)
H = pan -50 0
L = pan 50 0
J = pan 0 50
K = pan 0 -50

# quit -> hand off to the return script (restore vifm panes + sync cursor + close
# imv). Trivial bind on purpose: imv splits binds on ';' and treats each part as
# an imv command, so anything fancier than a bare script path gets mis-parsed
# (an inline shell pipeline never closed imv). $HOME expands via the exec shell.
q = exec $HOME/.config/imv/imv-vifm-return.sh quit
<Escape> = exec $HOME/.config/imv/imv-vifm-return.sh quit
