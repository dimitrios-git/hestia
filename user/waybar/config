{
    "layer": "top",
    "position": "top",
    "height": 32,
    "modules-left": ["custom/launcher", "sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["tray", "custom/cpu", "memory", "custom/gpu", "power-profiles-daemon", "custom/audio", "sway/language", "network", "bluetooth", "custom/usb", "custom/notifications", "custom/weather", "clock", "custom/power"],

    "custom/gpu": {
        "format": "<span size='xx-large' rise='-3072'>󰢮</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/gpu.sh",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-gpu && swaymsg '[app_id=\"^floatterm-gpu$\"] kill' || kitty --class floatterm-gpu -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/gpu-watch.sh"
    },

    "power-profiles-daemon": {
        "format": "<span size='xx-large' rise='-3072'>{icon}</span>",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "󰓅",
            "performance": "󰓅",
            "balanced": "󰾅",
            "power-saver": "󰌪"
        }
    },

    "bluetooth": {
        "format": "<span size='x-large' rise='-2560'>󰂯</span>",
        "format-disabled": "<span size='x-large' rise='-2560'>󰂲</span>",
        "format-off": "<span size='x-large' rise='-2560'>󰂲</span>",
        "format-connected": "<span size='x-large' rise='-2560'>󰂱</span> {num_connections}",
        "tooltip-format": "{controller_alias}\t{status}",
        "tooltip-format-connected": "{controller_alias}\t{status}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "pgrep -u $USER -x bluetuith >/dev/null && pkill -u $USER -x bluetuith || kitty --class floatterm -e bluetuith",
        "on-click-right": "rfkill toggle bluetooth"
    },

    "network": {
        "format-wifi": "<span size='xx-large' rise='-3072'>󰖩</span> {signalStrength:>2}%",
        "format-ethernet": "<span size='xx-large' rise='-3072'>󰈀</span>",
        "format-disconnected": "<span size='xx-large' rise='-3072'>󰖪</span>",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "pgrep -u $USER -x nmtui >/dev/null && pkill -u $USER -x nmtui || kitty --class floatterm -e nmtui"
    },

    "sway/language": {
        "format": "<span size='xx-large' rise='-3072'>󰗊</span> {short}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },


    "sway/workspaces": {
        "disable-scroll": true
    },

    "custom/cpu": {
        "format": "<span size='xx-large' rise='-3072'>󰻠</span> {}",
        "return-type": "json",
        "interval": 2,
        "exec": "$HOME/.config/waybar/scripts/cpu.sh",
        "on-click": "pgrep -u $USER -x htop >/dev/null && pkill -u $USER -x htop || kitty --class floatterm -e htop"
    },

    "memory": {
        "format": "<span size='xx-large' rise='-3072'>󰍛</span> {used:>4.1f}G",
        "interval": 2,
        "tooltip-format": "RAM  {used:0.1f} / {total:0.1f} GiB ({percentage}%)\nfree {avail:0.1f} GiB · swap {swapUsed:0.1f} / {swapTotal:0.1f} GiB",
        "on-click": "pgrep -u $USER -x htop >/dev/null && pkill -u $USER -x htop || kitty --class floatterm -e htop"
    },

    "custom/audio": {
        "format": "{}",
        "return-type": "json",
        "interval": 1,
        "signal": 8,
        "exec": "$HOME/.config/waybar/scripts/audio.sh",
        "on-click": "$HOME/.config/waybar/scripts/audio.sh toggle-mute",
        "on-click-right": "$HOME/.config/waybar/scripts/audio.sh mixer",
        "on-scroll-up": "$HOME/.config/waybar/scripts/audio.sh up",
        "on-scroll-down": "$HOME/.config/waybar/scripts/audio.sh down"
    },

    "clock": {
        "format": "<span size='xx-large' rise='-3072'></span> {:%a %d, %H:%M:%S}",
        "interval": 1,
        "tooltip-format": "{:%A, %d %B %Y  %Z}\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#d7005f'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click": "shift_reset",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "custom/usb": {
        "format": "<span size='x-large' rise='-2560'>󰋊</span> {}",
        "return-type": "json",
        "interval": 5,
        "exec": "$HOME/.config/waybar/scripts/usb.sh",
        "on-click": "$HOME/.config/waybar/scripts/usb.sh menu"
    },

    "custom/notifications": {
        "format": "<span size='xx-large' rise='-3072'>󰂜</span>",
        "tooltip-format": "Notifications",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-notify && swaymsg '[app_id=\"^floatterm-notify$\"] kill' || kitty --class floatterm-notify -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/notifications.sh show"
    },

    "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "interval": 1800,
        "exec": "$HOME/.config/waybar/scripts/weather.sh",
        "on-click": "swaymsg -t get_tree | grep -q floatterm-weather && swaymsg '[app_id=\"^floatterm-weather$\"] kill' || kitty --class floatterm-weather -o confirm_os_window_close=0 -e $HOME/.config/waybar/scripts/weather.sh show"
    },

    "custom/launcher": {
        "format": "<span size='xx-large' rise='-3072'></span>",
        "tooltip-format": "Applications",
        "on-click": "pgrep -u $USER -x wofi >/dev/null && pkill -u $USER -x wofi || wofi --show drun"
    },

    "custom/power": {
        "format": "<span size='xx-large' rise='-3072'>󰐥</span>",
        "tooltip-format": "Power",
        "on-click": "$HOME/.config/waybar/scripts/power.sh menu"
    },

    "tray": {
        "spacing": 10
    }
}
