# cava — accent-anchored cool sweep through the hestia palette (accent #d7005f
# → magenta → blue → cyan). The visualiser is the one place the palette plays.

[general]
framerate = 60
# 0 = auto-fit the number of bars to the terminal width
bars = 0
bar_width = 1
bar_spacing = 0

[input]
# Talk to PipeWire directly (no PulseAudio layer on this system).
# 'auto' captures the default sink's MONITOR (playback), not the mic.
method = pipewire
source = auto

[output]
method = noncurses
channels = stereo

[color]
# inherit the terminal (kitty) background
background = default
gradient = 1
# Accent-anchored cool sweep through adjacent hestia hues: dark accent → accent
# → magenta → blue → cyan, brightening upward. Bottom (low freq) still reads as
# the system accent; stops are hue-adjacent so cava's interpolation stays clean.
gradient_count = 6
gradient_color_1 = '#88003a'
gradient_color_2 = '#d7005f'
gradient_color_3 = '#d787d7'
gradient_color_4 = '#0087d7'
gradient_color_5 = '#00afff'
gradient_color_6 = '#00d7d7'

[smoothing]
# int 0-100 (was 0.77 ≈ no smoothing on this scale); higher = smoother
noise_reduction = 88
# horizontal smoothing — neighbouring bars influence each other for a flowing contour
monstercat = 1.5
waves = 0
