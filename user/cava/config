# cava — accent-anchored cool sweep through the hestia palette (violet accent
# #7c3aed → blue → cyan). The visualiser is the one place the palette plays.

[general]
framerate = 60
# 0 = auto-fit the number of bars to the terminal width
bars = 0
bar_width = 1
bar_spacing = 0

[input]
# Talk to PipeWire directly (no PulseAudio layer on this system).
# 'auto' captures the default sink's MONITOR (playback), not the mic.
method = pipewire
source = auto

[output]
method = noncurses
channels = stereo

[color]
# inherit the terminal (kitty) background
background = default
gradient = 1
# Accent-anchored cool sweep through adjacent hestia hues: deep violet → accent
# violet → light violet → blue → bright blue → cyan, brightening upward (0.10.0:
# re-anchored on the violet accent, mirroring the red→violet flip). Bottom (low
# freq) reads as the system accent; stops are hue-adjacent so cava interpolates
# cleanly. Truecolor (cava supports it), so these are the exact palette hexes.
gradient_count = 6
gradient_color_1 = '#5b21b6'
gradient_color_2 = '#7c3aed'
gradient_color_3 = '#9e77f7'
gradient_color_4 = '#4a8fe4'
gradient_color_5 = '#00afff'
gradient_color_6 = '#22cdda'

[smoothing]
# int 0-100 (was 0.77 ≈ no smoothing on this scale); higher = smoother
noise_reduction = 88
# horizontal smoothing — neighbouring bars influence each other for a flowing contour
monstercat = 1.5
waves = 0
