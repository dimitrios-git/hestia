---
# Per-host Ansible variables for `localhost` (this machine).
#
# Normally you don't write this by hand — **`bootstrap/setup.sh` generates it**
# interactively. This `.example` documents the format; copy it to `localhost.yml`
# (same dir) only if you prefer to fill it in manually. `localhost.yml` is
# gitignored so the personal values never reach the public repo.
#
#   cp localhost.yml.example localhost.yml   # then edit
#
# Ansible auto-loads host_vars/<inventory_hostname>.yml, so the override applies
# with no extra flags.

# Machine hostname (the `hostname` role sets /etc/hostname + /etc/hosts). estia
# names machines after the Greek pantheon, mapped to role — e.g. hephaestus (the
# forge/dev box), hermes (the cloud host). Omit to leave the hostname unmanaged.
system_hostname: "hephaestus"

# Install LibreOffice (vifm's office-doc opener)? Heavy (~hundreds of MB) and
# off by default — everything else works without it. Set true to opt in.
enable_libreoffice: false

# Install the proprietary NVIDIA driver (Debian non-free)? Off by default; host-
# specific and needs a reboot. setup.sh detects a card and pre-answers this.
enable_nvidia: false

# Home LAN subnet allowed to reach the Samba share (smb.conf `hosts allow`).
# Find it with: ip -o -4 addr show | awk '{print $4}'
samba_lan_subnet: "192.0.2.0/24"    # e.g. 192.168.1.0/24

# Where your music library lives (cmus browser default + the `U` rescan binding).
# Defaults to ~/Music if unset — override only if your library is elsewhere.
cmus_music_dir: "/mnt/storage/Music"   # e.g. an external mount

# Identity — rendered into ~/.gitconfig + the login credential-unlock scripts.
# setup.sh auto-detects these (git config / first GPG secret key + keygrip /
# ~/.ssh/id_*); set them here only to override.
git_user_name: "Your Name"
git_user_email: "you@example.com"
git_signingkey: ""           # GPG key id; blank → commit signing off
gpg_keygrip: ""              # keygrip of that key (gpg --list-secret-keys --with-keygrip)
ssh_key_file: "id_ed25519"   # private key in ~/.ssh loaded by the login hook

# Tip: you can wholesale-override any manifest list here too (e.g. your own
# `nerd_fonts:` / `localbin_binaries:` / `apt_packages:`). For installing extra
# software / running your own tasks, use bootstrap/local.yml — see
# ../../docs/personalizing.md.
