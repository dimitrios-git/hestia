### Variables

set $mod Mod4

default_border pixel 1
for_window [app_id=".*"] border pixel 1
for_window [class=".*"] border pixel 1
# Floating popups for tray/widget click actions (nmtui, etc.). The app_id criterion is
# an unanchored regex, so it also matches the per-widget classes (floatterm-gpu,
# floatterm-weather, …). The weather forecast is wide, so size that one larger (a later
# matching rule's `resize set` wins).
for_window [app_id="floatterm"] floating enable, resize set 800 600
for_window [app_id="floatterm-weather"] resize set 1180 720
for_window [app_id="floatterm-gpu"] resize set 1100 700

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
set $term kitty
set $menu wmenu-run

# Colors
set $bg      #0a0a0a
set $surface #111111
set $border  #1e1e1e
set $text    #e0e0e0
set $dim     #555555
set $accent  #ce0056

# Window colors:          border    bg        text    indicator  child_border
client.focused            $accent   $surface  $text   $accent    $accent
client.focused_inactive   $border   $bg       $dim    $border    $border
client.unfocused          $border   $bg       $dim    $border    $border
client.urgent             $accent   $accent   #ffffff $accent    $accent

include /etc/sway/config-vars.d/*

### Output configuration

# Identify monitors by serial (both are DELL U3219Q) so the layout is
# correct regardless of which DisplayPort socket each one is plugged into.
set $left_mon  "Dell Inc. DELL U3219Q 6L1L413"
set $right_mon "Dell Inc. DELL U3219Q 567V413"

output $left_mon  resolution 3840x2160 position 0,0 scale 1
output $right_mon resolution 3840x2160 position 3840,0 scale 1
output * bg #0a0a0a solid_color

# Pin workspaces to physical screens: odd -> left, even -> right
workspace 1 output $left_mon
workspace 3 output $left_mon
workspace 5 output $left_mon
workspace 7 output $left_mon
workspace 9 output $left_mon
workspace 2 output $right_mon
workspace 4 output $right_mon
workspace 6 output $right_mon
workspace 8 output $right_mon
workspace 10 output $right_mon

gaps inner 8
# Cancel the top edge gap so windows sit flush under Waybar (no gutter),
# while keeping inner gaps between windows.
gaps top -8
smart_gaps on

### Input configuration

# Bulgarian uses the traditional phonetic variant (W -> в); the comma
# positions in xkb_variant align variants to their layouts in xkb_layout.
# caps:super maps Caps Lock to Super; Alt+Shift cycles layouts.
input type:keyboard {
    xkb_layout "us,de,gr,bg"
    xkb_variant ",,,phonetic"
    xkb_options caps:super,grp:alt_shift_toggle
}

### Key bindings

# Basics
    bindsym $mod+Return exec $term
    bindsym $mod+Shift+q kill
    bindsym $mod+d exec wofi --show drun
    # Music: cmus + cava visualizer side by side
    bindsym $mod+m exec kitty --session music.session
    # Calculator: qalc (Qalculate CLI) in a floatterm — the floatterm app_id
    # triggers the `floating enable, resize set 800 600` rule above. Toggles like
    # the waybar widgets (pgrep -x): a second $mod+c closes it instead of stacking.
    bindsym $mod+c exec pgrep -x qalc >/dev/null && pkill -x qalc || kitty --class floatterm -e qalc

    # Drag floating windows with $mod + left mouse, resize with $mod + right.
    floating_modifier $mod normal

    bindsym $mod+Shift+c reload
    bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

# Moving around
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Move the focused window with the same, but add Shift
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

# Workspaces
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10
    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10

# Layout
    # $mod+b / $mod+v split horizontally / vertically
    bindsym $mod+b splith
    bindsym $mod+v splitv

    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    bindsym $mod+f fullscreen
    bindsym $mod+Shift+space floating toggle
    bindsym $mod+space focus mode_toggle
    bindsym $mod+a focus parent

# Scratchpad
    bindsym $mod+Shift+minus move scratchpad
    bindsym $mod+minus scratchpad show

# Resizing containers
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Utilities
    bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    bindsym XF86AudioPlay exec playerctl play-pause
    bindsym XF86AudioNext exec playerctl next
    bindsym XF86AudioPrev exec playerctl previous
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
    # Region screenshot: Print saves locally (~/Pictures/Screenshots); $mod+Print
    # saves to the shared /srv/clipshare so the `claude` agent can Read it (it runs
    # as a separate user and can't reach this session's clipboard). See screenshot.sh.
    bindsym Print exec $HOME/.config/sway/scripts/screenshot.sh local
    bindsym $mod+Print exec $HOME/.config/sway/scripts/screenshot.sh shared

### D-Bus / portals

# Export the Wayland session env to the D-Bus and systemd user activation
# environment so xdg-desktop-portal and its wlroots screencast backend start
# with the right context. Required for screen sharing (Teams/Edge, etc.) —
# without it the portal activates blind to the Sway session. Runs once at
# startup (a relogin re-runs it); see also ~/.config/xdg-desktop-portal/.
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE

# Dark appearance for GTK / portal-aware apps (Firefox, libadwaita). Two gsettings
# keys, because portal-mediated apps — notably the GTK file chooser — read gsettings,
# NOT ~/.config/gtk-3.0/settings.ini:
#   color-scheme prefer-dark : the Settings-portal value Firefox/libadwaita read for
#                              dark mode (else they default to light).
#   gtk-theme hestia-dark     : the GTK3 theme (recoloured adw-gtk3 from the gtk_theme
#                              role) — this is what carries the #ce0056 accent to GTK3
#                              apps (Remmina, GIMP, Firefox's file chooser); the portal
#                              file chooser reads it from gsettings, not settings.ini.
# dconf persists both; needs gsettings-desktop-schemas. NOTE: GTK4/libadwaita apps can't
# take the accent on Debian's libadwaita 1.7 (the accent is locked) — they're dark but
# keep the default blue accent until libadwaita 1.8; see docs/theming.md.
exec gsettings set org.gnome.desktop.interface color-scheme prefer-dark
exec gsettings set org.gnome.desktop.interface gtk-theme hestia-dark
# Icon theme: the #ce0056-accent Yaru built by the opt-in yaru_icons role (Yaru-hestia).
# Guard on the theme actually existing so a spin without that role doesn't force a missing
# theme (portal/file-chooser read icon-theme from gsettings, like gtk-theme above).
exec sh -c 'test -d "$HOME/.local/share/icons/Yaru-hestia" && gsettings set org.gnome.desktop.interface icon-theme Yaru-hestia'

### Credentials — auto-unlock SSH + GPG from the login keyring
# pam_gnome_keyring unlocks the gnome-keyring Secret Service at login; this hook
# reads the SSH + GPG passphrases from it and loads them into the ssh-agent /
# gpg-agent, so neither needs a per-boot ssh-add / gpg-unlock. See
# docs/credential-autounlock-design.md.
exec $HOME/.config/sway/scripts/credential-unlock.sh

### Bar, notifications, idle

exec_always $HOME/.config/sway/scripts/start-waybar.sh
exec_always pkill mako; mako

bindsym $mod+ctrl+l exec swaylock -f

# Idle inhibition — keep the screen from locking / DPMS-off while a media app is
# *fullscreen* (movies, fullscreen YouTube), the modern "caffeine". sway raises a
# Wayland idle inhibitor for these windows while fullscreen; swayidle honours it,
# so the lock timers below pause until you leave fullscreen, then resume. Scoped
# to media apps on purpose: a blanket rule would let a forgotten fullscreen
# terminal skip the auto-lock (the security boundary). app_id is an unanchored
# regex, so "firefox" also matches firefox-esr, and "^FFPWA-" matches every
# firefoxpwa web app (Netflix, YouTube, …) — each PWA gets its own FFPWA-<id>
# app_id, so a prefix match is required to cover them all.
for_window [app_id="firefox"]  inhibit_idle fullscreen
for_window [app_id="chromium"] inhibit_idle fullscreen
for_window [app_id="mpv"]      inhibit_idle fullscreen
for_window [app_id="^FFPWA-"]  inhibit_idle fullscreen

# 30s before the lock, dim *all* outputs to 40% (gammastep software gamma, not
# backlight — this desktop's external DP monitors expose no /sys/class/backlight,
# so brightnessctl can't touch them) and raise a persistent red notice. The dim
# is the unmissable cue across both 32" screens regardless of which one has focus;
# any input before 300s fires the `resume`, which kills gammastep and restores
# full brightness (lock never happens). Temp 6500 = neutral, so it's a pure
# brightness drop, no colour shift.
#
# gammastep MUST be backgrounded (&): on Wayland its -O "one-shot" doesn't exit —
# wlroots resets the gamma ramp the instant the setting client disconnects, so
# gammastep stays alive to *hold* the dim. swayidle -w waits for each timeout
# command to finish, so a foreground gammastep would wedge swayidle forever (no
# resume, no lock). Backgrounding lets the notify-send return; `resume` then
# `pkill`s gammastep (the disconnect restores brightness) AND dismisses the
# warning. The -t 30000 timeout would otherwise leave the "Locking in 30 seconds"
# notice on screen for the full 30s after input already cancelled the lock, so on
# resume we dismiss it by id: notify-send -p prints the id (stashed in tmpfs) and
# makoctl dismiss -n <id> clears that one notification (not -a, which would also
# drop unrelated notifications on every wake).
exec_always pkill swayidle; swayidle -w \
    timeout 270 'pkill -x gammastep; gammastep -O 6500 -b 0.4 & notify-send -p -u critical -t 30000 "Locking in 30 seconds" > "$XDG_RUNTIME_DIR/lock-warn.id"' \
        resume 'pkill -x gammastep; id=$(cat "$XDG_RUNTIME_DIR/lock-warn.id" 2>/dev/null); [ -n "$id" ] && makoctl dismiss -n "$id"; rm -f "$XDG_RUNTIME_DIR/lock-warn.id"' \
    timeout 300 'swaylock -f' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock -f'

# XWayland
xwayland enable

include /etc/sway/config.d/*
