{
  "document": {
    "block_prefix": "",
    "block_suffix": "",
    "color": "#d4d4d4",
    "margin": 2
  },
  "block_quote": {
    "color": "#8a8a8a",
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#ce0056",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#ffffff",
    "background_color": "#ce0056",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#ce0056",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#f06ba0",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#f06ba0",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "color": "#f06ba0",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "color": "#f06ba0"
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#ce0056",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#ce0056",
    "underline": true
  },
  "link_text": {
    "color": "#f06ba0",
    "bold": true
  },
  "image": {
    "color": "#ce0056",
    "underline": true
  },
  "image_text": {
    "color": "#8a8a8a",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#f06ba0",
    "background_color": "#1a1a1a"
  },
  "code_block": {
    "color": "#c4c4c4",
    "margin": 2,
    "chroma": {
      "text": { "color": "#c4c4c4" },
      "error": { "color": "#f1f1f1", "background_color": "#ce0056" },
      "comment": { "color": "#676767" },
      "comment_preproc": { "color": "#ff875f" },
      "keyword": { "color": "#00aaff" },
      "keyword_reserved": { "color": "#ff5fd2" },
      "keyword_namespace": { "color": "#ff5f87" },
      "keyword_type": { "color": "#6e6ed8" },
      "operator": { "color": "#ef8080" },
      "punctuation": { "color": "#e8e8a8" },
      "name": { "color": "#c4c4c4" },
      "name_builtin": { "color": "#ff8ec7" },
      "name_tag": { "color": "#b083ea" },
      "name_attribute": { "color": "#7a7ae6" },
      "name_class": { "color": "#f1f1f1", "underline": true, "bold": true },
      "name_constant": { "color": "#22d8df", "bold": true },
      "name_decorator": { "color": "#ffff87", "bold": true },
      "name_function": { "color": "#00d787" },
      "literal_number": { "color": "#ff6eb4" },
      "literal_string": { "color": "#22ee99" },
      "literal_string_escape": { "color": "#00aaff" },
      "generic_deleted": { "color": "#ce0056" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#00d787" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#777777" },
      "background": { "background_color": "#1a1a1a" }
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
