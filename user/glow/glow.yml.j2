# glow config — RENDERED by Ansible (bootstrap `dotfiles` role) to
# ~/.config/glow/glow.yml. NOT symlinked: glow can't expand ~ or $VARS in
# `style:`, so the absolute path is templated from {{ target_home }} (path
# generalisation — docs/repo-structure-design.md §5). Edit this .j2 and re-run the
# dotfiles role to apply (direct-edit is lost for this one file, by design).
style: "{{ target_home }}/.config/glow/wildcharm.json"
# mouse support (TUI-mode only)
mouse: false
# use pager to display markdown (vim :Glow and vifm pass -p explicitly anyway)
pager: false
# word-wrap at width — fallback for a bare `glow <file>` only. The two real
# consumers override it: the full-screen pager (vim :Glow, vifm open) passes
# -w "$(tput cols)" to wrap at the actual terminal width, and the vifm preview
# pane passes -w %pw. glow's own built-in default also caps wrapping at 80, so
# this just makes the bare-invocation width explicit.
width: 80
