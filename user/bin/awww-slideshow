#!/bin/bash
# awww-slideshow — minimal slideshow driver for awww, which (like swww before
# it) has transitions but no built-in cycling. Part of the wallpaper
# EVALUATION set (enable_wallpapers); symlinked into ~/.local/bin.
#
# Usage: awww-slideshow [-d SECONDS] [-t TRANSITION] DIR
#   -d  seconds between wallpapers (default 1800)
#   -t  awww transition type (default random; see `awww img --help`)
# Needs a running `awww-daemon` (started separately). Loops forever in a
# shuffled order, reshuffling each full pass — run it backgrounded or from an
# `exec` line. Images: anything awww loads (png/jpg/webp/gif/...).

set -eu

delay=1800
transition=random
while getopts d:t: opt; do
    case $opt in
        d) delay=$OPTARG ;;
        t) transition=$OPTARG ;;
        *) echo "usage: awww-slideshow [-d SECONDS] [-t TRANSITION] DIR" >&2; exit 2 ;;
    esac
done
shift $((OPTIND - 1))
dir=${1:?usage: awww-slideshow [-d SECONDS] [-t TRANSITION] DIR}

[ -d "$dir" ] || { echo "awww-slideshow: not a directory: $dir" >&2; exit 1; }

# Only formats awww decodes — a bare `find -type f` fed it .xmp sidecars and
# the like, and one bad file must not kill the loop (caught live 2026-07).
img_find() {
    find "$dir" -maxdepth 1 -type f ! -name '.*' \( \
        -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o \
        -iname '*.gif' -o -iname '*.webp' -o -iname '*.bmp' -o \
        -iname '*.tiff' -o -iname '*.tif' -o -iname '*.pnm' -o \
        -iname '*.tga' -o -iname '*.svg' \) "$@"
}

fails=0
while :; do
    while IFS= read -r -d '' img; do
        if awww img "$img" --transition-type "$transition"; then
            fails=0
        else
            # a corrupt file shouldn't end the show — but a dead daemon must
            fails=$((fails + 1))
            echo "awww-slideshow: skipping $img (failure $fails/5)" >&2
            [ "$fails" -ge 5 ] && { echo "awww-slideshow: 5 consecutive failures — is awww-daemon running?" >&2; exit 1; }
            continue
        fi
        sleep "$delay"
    done < <(img_find -print0 | shuf -z)
    # no usable images: don't spin
    [ -n "$(img_find -print -quit)" ] || sleep "$delay"
done
