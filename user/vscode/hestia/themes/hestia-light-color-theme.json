{
  "_provenance": "GENERATED by themes/wildcharm/render.py from palette.yml v0.5.0 + scopes.yml — do not edit; edit the sources and re-render",
  "name": "hestia-light",
  "type": "light",
  "colors": {
    "focusBorder": "#d7005f",
    "textLink.foreground": "#d7005f",
    "textLink.activeForeground": "#d7005f",
    "editorLink.activeForeground": "#d7005f",
    "editor.background": "#ffffff",
    "editor.foreground": "#1a1a1a",
    "editorCursor.foreground": "#d7005f",
    "editorLineNumber.foreground": "#6c6c6c",
    "statusBar.background": "#d7005f",
    "statusBar.foreground": "#ffffff",
    "button.background": "#d7005f",
    "button.foreground": "#ffffff",
    "badge.background": "#d7005f",
    "badge.foreground": "#ffffff"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6c6c6c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#008700"
      }
    },
    {
      "name": "String escape / regex / interpolation",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "punctuation.section.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#5f00d7"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#af0000"
      }
    },
    {
      "name": "Language variable (self/this)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#af0000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword (vim Statement, not bold)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#005faf"
      }
    },
    {
      "name": "Storage (vim StorageClass -> Type)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#af5f00"
      }
    },
    {
      "name": "Function/class keywords stay keywords",
      "scope": [
        "storage.type.function",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#005faf"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#870087"
      }
    },
    {
      "name": "Type / class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#af5f00"
      }
    },
    {
      "name": "Preprocessor / import",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.directive",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#005f5f"
      }
    },
    {
      "name": "Plain (variables, punctuation)",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#1a1a1a"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#005faf"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#af5f00"
      }
    },
    {
      "name": "Heading (vim Title)",
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#1a1a1a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#1a1a1a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Link",
      "scope": [
        "markup.underline.link",
        "markup.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#d7005f",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Raw / code span",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#005f5f"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#00875f"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#d70000"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#005fd7"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#d70000"
      }
    }
  ]
}
