" vim: ft=vim

" General

colorscheme wildcharm

set vicmd=vim
set trash
set trashdir=~/.local/share/Trash/files
set history=100
set followlinks
set sortnumbers
set undolevels=100
set vimhelp
set norunexec
set timefmt='%Y/%m/%d %H:%M'
set wildmenu
set wildstyle=popup
set ignorecase
set smartcase
set nohlsearch
set incsearch
set scrolloff=4

" Show a live preview of the selected file in the other (right) pane on startup.
" `w` (mapped below) toggles it off/on. `view!` is idempotent — it ensures quick
" view is ON rather than toggling, so it sticks when vifmrc runs at launch.
view!

" Marks

mark h ~/
mark D ~/Downloads/
mark d ~/Documents/
mark c ~/.config/
mark v ~/Videos/
mark p ~/Pictures/

" File associations (filextype = Wayland/X11 GUI apps)

" Images — Enter/l opens the integrated imv browser (imv-browse.sh): collapse
" vifm to one pane + tile imv to the RIGHT on the folder's images (config-vifm:
" live cursor sync on j/k, q returns). Idempotent — opening another image while
" imv is up just jumps the open imv to it (imv-msg goto) and focuses, instead of
" stacking a second pane. imv-browse.sh drives vifm's panes via `vifm --remote`,
" so it works from this shell handler (unlike an in-keybind :only). Full design:
" CLAUDE.md "vifm↔imv integrated image browsing".
filextype {*.jpg,*.jpeg,*.png,*.gif,*.bmp,*.tiff,*.tif,*.webp,*.avif,*.ico,*.svg}
        \ imv-browse.sh %c:p %d &

" Video — opens the SAME integrated imv browser as images (imv-browse.sh): the
" folder's videos appear as ▶ poster thumbnails alongside images, browsed with
" j/k; Enter on a video promotes it to mpv. (Direct play is still `mpv` via the
" {mpv} :file menu entry / the audio fallback.)
filextype {*.avi,*.mp4,*.wmv,*.dat,*.3gp,*.ogv,*.mkv,*.mpg,*.mpeg,*.vob,
          \*.m2v,*.mov,*.flv,*.ts,*.webm,*.m4v,*.m4b}
        \ imv-browse.sh %c:p %d &

" Audio — play in cmus (falls back to mpv --no-video if cmus isn't running)
filetype {*.wav,*.mp3,*.flac,*.ogg,*.m4a,*.opus,*.aac,*.wv}
       \ {Play in cmus} sh -c 'if pgrep -x cmus >/dev/null; then cmus-remote -f "$@"; else mpv --no-video "$@"; fi' _ %f,
       \ {Queue in cmus} cmus-remote -q %f,
       \ {mpv (no video)} mpv --no-video %f

" Markdown — render in glow (TUI pager); falls back to editing in vim.
" -w wraps at the real terminal width (glow's built-in default caps at 80 cols
" even on a wide terminal). The -2 is glamour's 2-col document left margin:
" tables are sized to the wrap width then indented by it, so at exactly
" $(tput cols) the table border overruns by 2 and wraps — subtract it.
filetype {*.md,*.markdown}
       \ {Render in glow} glow -w $(($(tput cols) - 2)) -p %f,
       \ {Edit in vim} vim %f

" PDF
filextype {*.pdf}
        \ zathura %f 2>/dev/null &,
        \ mupdf %f 2>/dev/null &

" epub / djvu / comic books — all handled by zathura plugins
filextype {*.epub,*.djvu,*.cbr,*.cbz}
        \ zathura %f 2>/dev/null &

" Office documents
filextype {*.odt,*.ods,*.odp,*.docx,*.doc,*.xlsx,*.xls,*.pptx,*.ppt}
        \ libreoffice %f &

" Archives — list contents
filetype {*.tar.gz,*.tgz,*.tar.bz2,*.tbz2,*.tar.xz,*.txz,*.tar.zst}
       \ {View} tar tf %f | less
filetype {*.zip}
       \ {View} unzip -l %f | less,
       \ {Extract} unzip %f
filetype {*.rar}
       \ {View} unrar l %f | less,
       \ {Extract} unrar x %f
filetype {*.7z}
       \ {View} 7z l %f | less,
       \ {Extract} 7z x %f

" Preview pane (toggle with w)

" Images — text info only (mediainfo: dimensions, format, colour depth). In-pane
" image *rendering* was tried (chafa sixels, kitty icat) and dropped: the
" graphics didn't display in vifm's pane on this kitty, and rendering on every
" cursor move made scrolling an image folder laggy (keystroke backlog). Press
" Enter to open the actual image in imv — fast, separate window (filextype above).
fileviewer {*.jpg,*.jpeg,*.png,*.gif,*.bmp,*.tiff,*.webp,*.avif,*.svg,*.ico}
         \ mediainfo %f

" Markdown — rendered preview (requires glow). Two pipe/notty gotchas:
"   * CLICOLOR_FORCE=1 forces colour. When piped (the preview pane is notty),
"     glow drops colour AND emits malformed empty-param SGR (ESC[;;1m) for the
"     bold-only bits, which vifm's ANSI parser can't read — it leaks them as
"     literal "1m" in the pane. -s alone does NOT fix this (it only carries the
"     style's bold, not colour). CLICOLOR_FORCE makes glow emit well-formed SGR
"     (like bat --color=always), which vifm renders cleanly. Note: forced notty
"     output is 16-colour (no truecolor), so it's an approximation of the
"     wildcharm hex — the full-screen open (real TTY) still gets truecolor.
"   * -s passes the wildcharm style so the 16-colour mapping stays on-theme.
fileviewer {*.md,*.markdown}
         \ CLICOLOR_FORCE=1 glow -s ~/.config/glow/wildcharm.json -w %pw %f

" PDF — requires poppler-utils
fileviewer {*.pdf}
         \ pdftotext -l 10 -nopgbrk %f - 2>/dev/null

" Audio / video metadata — requires mediainfo
fileviewer {*.mp4,*.mkv,*.avi,*.mov,*.webm,*.flv,*.mp3,*.flac,*.ogg,*.m4a,*.opus}
         \ mediainfo %f

" Archives
fileviewer {*.tar.gz,*.tgz,*.tar.bz2,*.tbz2,*.tar.xz,*.txz}
         \ tar tf %f
fileviewer {*.zip}
         \ unzip -l %f
fileviewer {*.7z}
         \ 7z l %f

" Everything else — syntax-highlighted code/text preview via bat (wildcharm
" theme), with a binary/directory fallback. Catch-all goes LAST so the specific
" viewers above win (vifm uses the first matching :fileviewer). preview.sh lives
" in ~/.config/vifm/scripts (on vifm's PATH); %pw/%ph size output to the pane.
fileviewer {*}
         \ preview.sh %f %pw %ph

" Key bindings

" Open shell in current directory
nnoremap s :shell<cr>

" Toggle preview pane
nnoremap w :view<cr>
vnoremap w :view<cr>gv

" Sort dialog
nnoremap S :sort<cr>

" Yank current dir/file path to Wayland clipboard (requires wl-clipboard)
nnoremap yd :!echo -n %d | wl-copy<cr>
nnoremap yf :!echo -n %c:p | wl-copy<cr>

" Open with xdg-open as fallback
nnoremap o :!xdg-open %f &<cr>

" Custom commands (:name [args])

" git: diff the file under the cursor against a branch, in vimdiff — short for
" the verbose `git difftool -y -t vimdiff master...HEAD -- <file>`.
"   :gd        vs the default branch's merge-base with HEAD; base auto-detected
"              (main, else master) so the same command works in either repo.
"   :gd <ref>  vs <ref> instead, e.g. :gd origin/main, :gd develop, :gd HEAD~3.
" The file is taken automatically (the cursor file) — do NOT pass it; the
" optional argument (%a) is only the base ref. An unknown base ref (e.g. a
" filename typed by mistake) is rejected with a clear message rather than git's
" cryptic `bad revision`. Foreground — vifm suspends until you :qa out of vim.
"
" It does NOT use `git difftool`: difftool only launches the tool for files that
" actually differ, so on an unmodified file it would just flash and do nothing.
" Instead it extracts both sides itself — the merge-base blob (`$mb:./$f`) and
" the HEAD blob — into a temp dir and opens `vim -d` on them, so :gd ALWAYS
" opens a diff view: changed files show the diff, unmodified files show two
" identical panes, a file new on the branch shows added-vs-empty. The temp
" blobs live under /tmp, outside any repo, so in-editor git plugins (coc-git,
" fugitive…) see "not a repo" and stay quiet — no GIT_DIR inheritance like the
" difftool path had. Missing side (added/deleted) → empty file. Flags mirror
" git's builtin vimdiff (-R -d, focus the HEAD pane).
command! gd !git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "gd: not inside a git repository"; exit 1; }; b='%a'; [ -z "$b" ] && b=$(git rev-parse -q --verify main >/dev/null 2>&1 && echo main || echo master); git rev-parse -q --verify "$b" >/dev/null 2>&1 || { echo "gd: unknown base ref '$b' (:gd takes the file automatically; the optional arg is a base ref like origin/main)"; exit 1; }; f=%c:t; mb=$(git merge-base "$b" HEAD 2>/dev/null || echo "$b"); d=$(mktemp -d) || exit 1; mkdir -p "$d/base" "$d/head"; git show "$mb:./$f" > "$d/base/$f" 2>/dev/null || : > "$d/base/$f"; git show "HEAD:./$f" > "$d/head/$f" 2>/dev/null || : > "$d/head/$f"; vim -R -d -c "wincmd l" "$d/base/$f" "$d/head/$f"; rm -rf "$d"
