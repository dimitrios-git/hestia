  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6c6c6c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
